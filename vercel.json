{
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/fonts/open-sans-latin-600.woff2",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/fonts/open-sans-:foo(\\w+).woff",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/fonts/open-sans-:foo(\\w+).woff2",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31537000, immutable"
        }
      ]
    }
  ]
}
